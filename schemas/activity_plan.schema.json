{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://numbersauto.local/schemas/activity_plan.schema.json",
  "title": "Activity Plan",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "lesson_id",
    "activities"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "lesson_id": {
      "type": "string"
    },
    "activities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "activity_id",
          "lesson_id",
          "activity_type",
          "level",
          "learning_goal",
          "prompt_text",
          "layout_template",
          "source_refs",
          "student_writing_zones",
          "estimated_minutes",
          "review_status"
        ],
        "properties": {
          "activity_id": {
            "type": "string"
          },
          "lesson_id": {
            "type": "string"
          },
          "object_role": {
            "type": "string",
            "enum": ["learning_note", "activity_area", "reference_material", "worksheet", "ai_courseware"]
          },
          "lesson_flow_stage": {
            "type": "string",
            "enum": ["before", "during", "after"]
          },
          "activity_type": {
            "type": "string",
            "enum": [
              "freeform_html",
              "learning_note",
              "see_think_wonder",
              "worksheet",
              "frayer_model",
              "reference_response",
              "spectrum_sorting"
            ]
          },
          "level": {
            "type": "string",
            "enum": ["core", "on-level", "extension"]
          },
          "learning_goal": {
            "type": "string"
          },
          "prompt_text": {
            "type": "string"
          },
          "layout_template": {
            "type": "string"
          },
          "html_content": {
            "type": "string"
          },
          "source_refs": {
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": 1
            },
            "minItems": 1
          },
          "teacher_notes": {
            "type": "string"
          },
          "student_writing_zones": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["zone_id", "label", "input_area_type", "min_height"],
              "properties": {
                "zone_id": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                },
                "input_area_type": {
                  "type": "string",
                  "enum": ["lined", "free-writing", "inline-answer", "grid", "spectrum"]
                },
                "min_height": {
                  "type": "integer",
                  "minimum": 40
                }
              },
              "additionalProperties": false
            }
          },
          "estimated_minutes": {
            "type": "integer",
            "minimum": 1
          },
          "review_status": {
            "type": "string",
            "enum": ["draft", "reviewed", "approved", "rejected"]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
