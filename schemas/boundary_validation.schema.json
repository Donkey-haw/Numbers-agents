{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://numbersauto.local/schemas/boundary_validation.schema.json",
  "title": "Boundary Validation",
  "type": "object",
  "required": ["schema_version", "status", "blocking_issues", "warnings", "entries"],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "blocking_issues": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["lesson_id", "resource_id", "status"],
        "properties": {
          "lesson_id": {
            "type": "string"
          },
          "resource_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
