{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://numbersauto.local/schemas/document_inventory.schema.json",
  "title": "Document Inventory",
  "type": "object",
  "required": ["schema_version", "documents"],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "documents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["document_id", "path", "kind", "exists"],
        "properties": {
          "document_id": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": ["textbook", "schedule_chart", "supplement", "reference", "unknown"]
          },
          "exists": {
            "type": "boolean"
          },
          "label": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
