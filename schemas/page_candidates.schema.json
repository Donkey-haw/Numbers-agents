{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://numbersauto.local/schemas/page_candidates.schema.json",
  "title": "Page Candidates",
  "type": "object",
  "required": ["schema_version", "lessons"],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "lessons": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["lesson_id", "resource_id", "candidate_pages"],
        "properties": {
          "lesson_id": {
            "type": "string"
          },
          "resource_id": {
            "type": "string"
          },
          "candidate_pages": {
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": 1
            }
          },
          "query": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
