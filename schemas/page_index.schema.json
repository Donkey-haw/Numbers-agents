{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://numbersauto.local/schemas/page_index.schema.json",
  "title": "Page Index",
  "type": "object",
  "required": ["schema_version", "document_id", "pages"],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "document_id": {
      "type": "string"
    },
    "pages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["page", "excerpt", "tokens", "heading_candidates"],
        "properties": {
          "page": {
            "type": "integer",
            "minimum": 1
          },
          "excerpt": {
            "type": "string"
          },
          "tokens": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "heading_candidates": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
