{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://numbersauto.local/schemas/render_manifest.schema.json",
  "title": "Render Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "output_file",
    "assets"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "output_file": {
      "type": "string"
    },
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "asset_id",
          "asset_type",
          "sheet_name",
          "insert_order",
          "html_path",
          "image_path",
          "dimensions"
        ],
        "properties": {
          "asset_id": {
            "type": "string"
          },
          "asset_type": {
            "type": "string",
            "enum": ["textbook_card", "supplement_card", "activity_sheet"]
          },
          "sheet_name": {
            "type": "string"
          },
          "insert_order": {
            "type": "integer",
            "minimum": 1
          },
          "html_path": {
            "type": "string"
          },
          "image_path": {
            "type": "string"
          },
          "source_json": {
            "type": "string"
          },
          "resource_id": {
            "type": "string"
          },
          "dimensions": {
            "type": "object",
            "required": ["width", "height"],
            "properties": {
              "width": {
                "type": "integer",
                "minimum": 1
              },
              "height": {
                "type": "integer",
                "minimum": 1
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
